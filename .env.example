# Supabase — frontend (publikus, RLS vedett)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase — szerver oldali (seed script, API routes)
# SOHA ne VITE_ prefix — nem kerulhet a frontend bundle-be
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini — server side only
# SOHA ne VITE_ prefix
GEMINI_API_KEY=your-gemini-api-key

# Admin — server side only
# SOHA ne VITE_ prefix
ADMIN_PASSWORD=your-admin-password

# GitHub Backup — server side only
# SOHA ne VITE_ prefix
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_REPO=owner/repo
GITHUB_BACKUP_BRANCH=main
